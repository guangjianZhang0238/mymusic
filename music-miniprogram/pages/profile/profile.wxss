.profile-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(244, 114, 182, 0.25);
}

.name {
  font-size: 30rpx;
  font-weight: 600;
}

.phone {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.favorites {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.song-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 16rpx;
  display: flex;
  gap: 16rpx;
  align-items: center;
  box-shadow: 0 10rpx 24rpx rgba(71, 85, 105, 0.14);
}

.cover {
  width: 90rpx;
  height: 90rpx;
  border-radius: 16rpx;
}
