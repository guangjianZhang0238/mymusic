.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero {
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.greeting {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
}

.desc {
  color: #6b7280;
  font-size: 26rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.section {
  margin-top: 16rpx;
}

.song-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.song-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 18rpx;
  display: flex;
  gap: 16rpx;
  align-items: center;
  box-shadow: 0 10rpx 24rpx rgba(71, 85, 105, 0.14);
}

.cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 18rpx;
}

.info {
  flex: 1;
}

.name {
  font-weight: 600;
}

.artist {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.song-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.song-tile {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 22rpx;
  padding: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(71, 85, 105, 0.14);
}

.tile-cover {
  width: 100%;
  height: 200rpx;
  border-radius: 18rpx;
}

.tile-name {
  margin-top: 12rpx;
  font-weight: 600;
}

.tile-artist {
  font-size: 22rpx;
  margin-top: 6rpx;
}
