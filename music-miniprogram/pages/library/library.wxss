.library-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.playlist-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.playlist-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: 0 10rpx 24rpx rgba(71, 85, 105, 0.14);
}

.playlist-main {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 18rpx;
}

.info {
  flex: 1;
}

.name {
  font-weight: 600;
}

.count {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  backdrop-filter: blur(6rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.modal {
  width: 640rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 26rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: 0 16rpx 30rpx rgba(15, 23, 42, 0.12);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
}

.textarea {
  min-height: 140rpx;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
